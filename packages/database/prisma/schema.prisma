// ==============================================================
// REVISOR DE TESIS — Prisma Schema (MySQL 8.x)
// Base de datos transaccional principal
// ==============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────

enum UserRole {
  ADMIN
  COORDINATOR
  ADVISOR
  STUDENT
}

enum DocumentStatus {
  UPLOADED
  EXTRACTING
  VECTORIZING
  ANALYZING
  REVIEWED
  ERROR
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  RATE_LIMITED
}

enum FindingSeverity {
  CRITICAL
  MAJOR
  MINOR
  INFO
}

enum FindingCategory {
  STRUCTURE
  CONTENT
  FORMAT
  CITATION
  GRAMMAR
  COHERENCE
}

enum CitationStatus {
  VERIFIED
  PARTIAL
  NOT_FOUND
  PENDING
}

enum NotificationType {
  AI_REVIEW_COMPLETE
  ADVISOR_APPROVED
  ADVISOR_REJECTED
  ADVISOR_FEEDBACK
  DEADLINE_REMINDER_48H
  DEADLINE_REMINDER_24H
}

// ─── USERS & AUTH ───────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  role          UserRole  @default(STUDENT)
  isActive      Boolean   @default(true) @map("is_active")
  avatarUrl     String?   @map("avatar_url")
  expoPushToken String?   @map("expo_push_token")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relaciones
  orcidProfile         OrcidProfile?
  refreshTokens        RefreshToken[]
  projectsAsStudent    ThesisProject[]      @relation("StudentProjects")
  projectsAsAdvisor    ThesisProject[]      @relation("AdvisorProjects")
  assignedAsCoordinator ThesisProject[]     @relation("CoordinatorProjects")
  feedbackCorrections  FeedbackCorrection[]
  notifications        Notification[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique @db.VarChar(512)
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model OrcidProfile {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  orcidId      String   @unique @map("orcid_id")
  accessToken  String?  @map("access_token") @db.Text
  refreshToken String?  @map("refresh_token") @db.Text
  displayName  String?  @map("display_name")
  biography    String?  @db.Text
  keywords     String?  @db.Text // JSON array de keywords
  works        String?  @db.LongText // JSON array de publicaciones importadas
  isVerified     Boolean  @default(false) @map("is_verified") 
  aiJustification String? @db.Text @map("ai_justification")
  lastSyncAt   DateTime? @map("last_sync_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("orcid_profiles")
}

// ─── THESIS PROJECTS ────────────────────────────────────────

model ThesisProject {
  id             String    @id @default(uuid())
  title          String    @db.VarChar(500)
  description    String?   @db.Text
  researchLine   String?   @map("research_line") @db.VarChar(300)
  studentId      String    @map("student_id")
  advisorId      String?   @map("advisor_id")
  coordinatorId  String?   @map("coordinator_id")
  patternId      String?   @map("pattern_id")
  currentPhase   String?   @map("current_phase") @db.VarChar(100)
  nextDeadline   DateTime? @map("next_deadline")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relaciones
  student      User               @relation("StudentProjects", fields: [studentId], references: [id])
  advisor      User?              @relation("AdvisorProjects", fields: [advisorId], references: [id])
  coordinator  User?              @relation("CoordinatorProjects", fields: [coordinatorId], references: [id])
  pattern      DocumentPattern?   @relation(fields: [patternId], references: [id])
  submissions  DocumentSubmission[]

  @@index([studentId])
  @@index([advisorId])
  @@index([coordinatorId])
  @@map("thesis_projects")
}

// ─── DOCUMENT PATTERNS (Templates) ─────────────────────────

model DocumentPattern {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(300)
  description String?  @db.Text
  version     String   @default("1.0") @db.VarChar(20)
  // Estructura JSON del patrón: capítulos, secciones, subsecciones, reglas de formato
  structure   String   @db.LongText // JSON: PatternStructure
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  projects ThesisProject[]

  @@map("document_patterns")
}

// ─── DOCUMENT SUBMISSIONS ───────────────────────────────────

model DocumentSubmission {
  id              String         @id @default(uuid())
  projectId       String         @map("project_id")
  fileName        String         @map("file_name") @db.VarChar(500)
  fileKey         String         @map("file_key") @db.VarChar(500) // Key en MinIO
  fileSize        Int            @map("file_size") // Bytes
  mimeType        String         @map("mime_type") @db.VarChar(100)
  extractedText   String?        @map("extracted_text") @db.LongText
  chunkCount      Int?           @map("chunk_count")
  status          DocumentStatus @default(UPLOADED)
  overallScore    Float?         @map("overall_score") // Nota sugerida 0-20
  advisorApproved Boolean?       @map("advisor_approved")
  advisorComment  String?        @map("advisor_comment") @db.Text
  submittedAt     DateTime       @default(now()) @map("submitted_at")
  reviewedAt      DateTime?      @map("reviewed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relaciones
  project             ThesisProject       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  aiReviewJobs        AiReviewJob[]
  findings            AiReviewFinding[]
  plagiarismAlerts    PlagiarismAlert[]
  citationValidations CitationValidation[]

  @@index([projectId])
  @@index([status])
  @@map("document_submissions")
}

// ─── AI REVIEW JOBS ─────────────────────────────────────────

model AiReviewJob {
  id           String    @id @default(uuid())
  submissionId String    @map("submission_id")
  jobType      String    @map("job_type") @db.VarChar(50) // embeddings, gemini, plagiarism, crossref
  bullJobId    String?   @map("bull_job_id") @db.VarChar(100)
  status       JobStatus @default(PENDING)
  attempts     Int       @default(0)
  lastError    String?   @map("last_error") @db.Text
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  submission DocumentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([status])
  @@map("ai_review_jobs")
}

// ─── AI REVIEW FINDINGS ─────────────────────────────────────

model AiReviewFinding {
  id              String          @id @default(uuid())
  submissionId    String          @map("submission_id")
  category        FindingCategory
  severity        FindingSeverity
  title           String          @db.VarChar(500)
  description     String          @db.Text
  instruction     String          @db.Text // Instrucción de corrección
  affectedSection String?         @map("affected_section") @db.VarChar(300)
  pageNumber      Int?            @map("page_number")
  suggestedScore  Float?          @map("suggested_score")
  originalText    String?         @map("original_text") @db.Text
  isResolved      Boolean         @default(false) @map("is_resolved")
  createdAt       DateTime        @default(now()) @map("created_at")

  // Relaciones
  submission         DocumentSubmission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  feedbackCorrection FeedbackCorrection?

  @@index([submissionId])
  @@index([severity])
  @@map("ai_review_findings")
}

// ─── PLAGIARISM ALERTS ──────────────────────────────────────

model PlagiarismAlert {
  id                String   @id @default(uuid())
  submissionId      String   @map("submission_id")
  sourceChunkText   String   @map("source_chunk_text") @db.Text
  matchedChunkText  String   @map("matched_chunk_text") @db.Text
  matchedDocumentId String   @map("matched_document_id")
  matchedFileName   String?  @map("matched_file_name") @db.VarChar(500)
  similarityScore   Float    @map("similarity_score") // 0.0 - 1.0
  chunkIndex        Int      @map("chunk_index")
  isReviewed        Boolean  @default(false) @map("is_reviewed")
  reviewerComment   String?  @map("reviewer_comment") @db.Text
  createdAt         DateTime @default(now()) @map("created_at")

  submission DocumentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([similarityScore])
  @@map("plagiarism_alerts")
}

// ─── CITATION VALIDATION ────────────────────────────────────

model CitationValidation {
  id             String         @id @default(uuid())
  submissionId   String         @map("submission_id")
  rawCitation    String         @map("raw_citation") @db.Text
  extractedTitle String?        @map("extracted_title") @db.VarChar(500)
  extractedDoi   String?        @map("extracted_doi") @db.VarChar(200)
  extractedYear  String?        @map("extracted_year") @db.VarChar(10)
  extractedAuthors String?      @map("extracted_authors") @db.Text
  crossrefDoi    String?        @map("crossref_doi") @db.VarChar(200)
  crossrefTitle  String?        @map("crossref_title") @db.VarChar(500)
  crossrefYear   String?        @map("crossref_year") @db.VarChar(10)
  crossrefAuthors String?       @map("crossref_authors") @db.Text
  status         CitationStatus @default(PENDING)
  matchScore     Float?         @map("match_score")
  createdAt      DateTime       @default(now()) @map("created_at")

  submission DocumentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([status])
  @@map("citation_validations")
}

// ─── FEEDBACK CORRECTIONS (Dataset Fine-Tuning Futuro) ──────

model FeedbackCorrection {
  id                  String   @id @default(uuid())
  findingId           String   @unique @map("finding_id")
  advisorId           String   @map("advisor_id")
  originalSeverity    FindingSeverity @map("original_severity")
  correctedSeverity   FindingSeverity? @map("corrected_severity")
  originalDescription String   @map("original_description") @db.Text
  correctedDescription String?  @map("corrected_description") @db.Text
  originalInstruction String   @map("original_instruction") @db.Text
  correctedInstruction String?  @map("corrected_instruction") @db.Text
  wasAccepted         Boolean  @map("was_accepted") // ¿El asesor aceptó la sugerencia de IA?
  advisorNotes        String?  @map("advisor_notes") @db.Text
  createdAt           DateTime @default(now()) @map("created_at")

  finding AiReviewFinding @relation(fields: [findingId], references: [id], onDelete: Cascade)
  advisor User            @relation(fields: [advisorId], references: [id])

  @@index([advisorId])
  @@map("feedback_corrections")
}

// ─── NOTIFICATIONS ──────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String           @db.VarChar(300)
  body      String           @db.Text
  data      String?          @db.Text // JSON con metadata extra
  isRead    Boolean          @default(false) @map("is_read")
  sentAt    DateTime?        @map("sent_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}
