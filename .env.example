# ============================================================
# PLATAFORMA REVISOR DE TESIS — Variables de Entorno
# Copiar este archivo como .env y completar los valores
# ============================================================

# === MySQL 8.x ===
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=revisor_tesis
MYSQL_USER=revisor
MYSQL_PASSWORD=revisor_secret_2025
MYSQL_ROOT_PASSWORD=root_secret_2025
DATABASE_URL=mysql://revisor:revisor_secret_2025@localhost:3306/revisor_tesis

# === Redis 7 ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_2025

# === MinIO (S3 Compatible) ===
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minio_secret_2025
MINIO_BUCKET_DOCUMENTS=thesis-documents
MINIO_BUCKET_PATTERNS=thesis-patterns
MINIO_USE_SSL=false

# === Qdrant (Vector DB) ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=thesis_chunks

# === Gemini API (Free Tier) ===
# Obtener GRATIS en: https://aistudio.google.com/apikey
GEMINI_API_KEY=MI_API_KEY_AQUI
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_RPM_LIMIT=12
GEMINI_MAX_RETRIES=5

# === ORCID (Sandbox — Gratis) ===
# Registrar en: https://sandbox.orcid.org/developer-tools
ORCID_CLIENT_ID=TU_ORCID_CLIENT_ID
ORCID_CLIENT_SECRET=TU_ORCID_CLIENT_SECRET
ORCID_REDIRECT_URI=http://localhost:3001/api/auth/orcid/callback
ORCID_SANDBOX=true

# === CrossRef (Gratis — Polite Pool) ===
CROSSREF_MAILTO=tu-email@universidad.edu.pe

# === JWT ===
JWT_SECRET=cambiar_por_secret_seguro_de_256_bits_minimo
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambiar_por_otro_secret_seguro_diferente
JWT_REFRESH_EXPIRES_IN=7d

# === Ports ===
API_PORT=3001
WEB_PORT=3000

# === Embeddings (Local) ===
EMBEDDING_MODEL=Xenova/nomic-embed-text-v1
EMBEDDING_DIMENSIONS=768
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# === General ===
NODE_ENV=development
